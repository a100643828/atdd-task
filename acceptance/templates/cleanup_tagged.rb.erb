# Test Suite Cleanup Script (Tagged Data Strategy)
#
# Suite: <%= suite_id %>
# Description: <%= description %>
# Generated: <%= Time.now.iso8601 %>
# Generated by: tester
#
# Usage:
#   cd <%= project_path %> && rails runner tests/<%= project_id %>/suites/<%= suite_id %>/fixtures/cleanup.rb <test_run_id>
#
# Tagged Data Strategy:
#   - 只清理指定 test_run_id 的資料
#   - 不影響其他測試或真實資料
#
# ⚠️  IMPORTANT: 必須提供 test_run_id 參數

module TestSuite
  module <%= suite_id.gsub('-', '_').camelize %>
    class Cleaner
      PREFIX = "TEST-"

      attr_reader :test_run_id, :deleted_counts

      def initialize(test_run_id)
        raise ArgumentError, "test_run_id is required" if test_run_id.nil? || test_run_id.empty?
        @test_run_id = test_run_id
        @deleted_counts = {}
      end

      def cleanup!
        puts "═" * 60
        puts "🧹 Test Suite Cleanup"
        puts "═" * 60
        puts "Suite: <%= suite_id %>"
        puts "Test Run ID: #{@test_run_id}"
        puts "═" * 60
        puts

        ActiveRecord::Base.transaction do
          # ─────────────────────────────────────────────────────────
          # 刪除測試資料（反向順序，處理外鍵關聯）
          # ─────────────────────────────────────────────────────────
          <% entities.reverse.each do |entity| %>

          # <%= entity[:name] %>
          cleanup_<%= entity[:name].underscore %>
          <% end %>

          # ─────────────────────────────────────────────────────────
          # 輸出結果
          # ─────────────────────────────────────────────────────────
          puts
          puts "═" * 60
          puts "✅ Cleanup completed successfully!"
          puts "═" * 60
          puts "Test Run ID: #{@test_run_id}"
          total = @deleted_counts.values.sum
          puts "Total records deleted: #{total}"
          @deleted_counts.each do |entity, count|
            puts "  - #{entity}: #{count}"
          end
          puts "═" * 60

          # 回傳結果供自動化使用
          {
            test_run_id: @test_run_id,
            records_deleted: total,
            by_entity: @deleted_counts
          }
        end
      rescue => e
        puts "❌ Error: #{e.message}"
        puts e.backtrace.first(5).join("\n")
        raise ActiveRecord::Rollback
      end

      private

      <% entities.each do |entity| %>

      def cleanup_<%= entity[:name].underscore %>
        # 方法 1: 透過 metadata 的 test_run_id 標記清理
        if <%= entity[:name] %>.column_names.include?('metadata')
          count = <%= entity[:name] %>.where("metadata->>'test_run_id' = ?", @test_run_id).delete_all
          @deleted_counts['<%= entity[:name] %>'] = count
          puts "✅ Deleted #{count} <%= entity[:name] %> records (by metadata)"
          return
        end

        # 方法 2: 透過 prefix 識別清理（備援）
        <% if entity[:identifier_field] %>
        prefix = "#{PREFIX}#{@test_run_id[0..7]}-"
        count = <%= entity[:name] %>.where("<%= entity[:identifier_field] %> LIKE ?", "#{prefix}%").delete_all
        @deleted_counts['<%= entity[:name] %>'] = count
        puts "✅ Deleted #{count} <%= entity[:name] %> records (by prefix)"
        <% else %>
        @deleted_counts['<%= entity[:name] %>'] = 0
        puts "⚠️  Skipped <%= entity[:name] %> (no identifier field)"
        <% end %>
      end
      <% end %>
    end
  end
end

# 執行
if __FILE__ == $0
  test_run_id = ARGV[0]

  if test_run_id.nil? || test_run_id.empty?
    puts "❌ Error: test_run_id is required"
    puts "Usage: rails runner cleanup.rb <test_run_id>"
    exit 1
  end

  cleaner = TestSuite::<%= suite_id.gsub('-', '_').camelize %>::Cleaner.new(test_run_id)
  cleaner.cleanup!
end
