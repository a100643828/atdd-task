# Acceptance Fixture Cleanup Script
#
# Task: <%= task_id %>
# Description: <%= description %>
# Generated: <%= Time.now.iso8601 %>
# Generated by: tester
#
# Usage:
#   cd <%= project_path %> && rails runner db/seeds/acceptance/<%= task_id %>_cleanup.rb
#
# This script removes test data created by the setup script.

module AcceptanceFixture
  PREFIX = "ACC-<%= task_id[0..7] %>-"

  class << self
    def cleanup
      puts "═" * 60
      puts "🧹 Acceptance Fixture Cleanup"
      puts "═" * 60
      puts "Task: <%= task_id %>"
      puts "═" * 60
      puts

      ActiveRecord::Base.transaction do
        # ─────────────────────────────────────────────────────────
        # 刪除測試資料（反向順序，處理外鍵關聯）
        # ─────────────────────────────────────────────────────────
        <% deletes.reverse.each do |delete| %>

        # <%= delete[:entity] %>
        <%= delete[:entity] %>.where("<%= delete[:identifier_field] %> LIKE ?", "#{PREFIX}%").destroy_all
        puts "✅ Deleted <%= delete[:entity] %> records with prefix: #{PREFIX}"
        <% end %>

        puts
        puts "═" * 60
        puts "✅ Acceptance data cleaned up successfully!"
        puts "═" * 60
      end
    rescue => e
      puts "❌ Error: #{e.message}"
      puts e.backtrace.first(5).join("\n")
      raise ActiveRecord::Rollback
    end
  end
end

AcceptanceFixture.cleanup
