# Acceptance Fixture Setup Script
#
# Task: <%= task_id %>
# Description: <%= description %>
# Generated: <%= Time.now.iso8601 %>
# Generated by: tester
#
# Usage:
#   cd <%= project_path %> && rails runner db/seeds/acceptance/<%= task_id %>_setup.rb
#
# This script creates test data for human acceptance verification.
# All data is prefixed with "ACC-" to avoid conflicts with real data.

module AcceptanceFixture
  # 驗收資料前綴，避免與真實資料衝突
  PREFIX = "ACC-<%= task_id[0..7] %>-"

  class << self
    def setup
      puts "═" * 60
      puts "🔧 Acceptance Fixture Setup"
      puts "═" * 60
      puts "Task: <%= task_id %>"
      puts "Description: <%= description %>"
      puts "═" * 60
      puts

      ActiveRecord::Base.transaction do
        # ─────────────────────────────────────────────────────────
        # 建立測試資料
        # ─────────────────────────────────────────────────────────
        <% creates.each do |create| %>

        # <%= create[:entity] %>
        <%= create[:variable] %> = <%= create[:entity] %>.create!(
          <% create[:attributes].each do |key, value| %>
          <%= key %>: <%= value.inspect %>,
          <% end %>
        )
        puts "✅ Created <%= create[:entity] %>: #{<%= create[:variable] %>.<%= create[:identifier_field] %>}"
        <% end %>

        # ─────────────────────────────────────────────────────────
        # 輸出驗收所需資訊
        # ─────────────────────────────────────────────────────────
        puts
        puts "═" * 60
        puts "✅ Acceptance data created successfully!"
        puts "═" * 60
        <% outputs.each do |output| %>
        puts "<%= output[:description] %>: #{<%= output[:value] %>}"
        <% end %>
        puts "═" * 60
        puts
        puts "⚠️  After verification, run cleanup script:"
        puts "    rails runner db/seeds/acceptance/<%= task_id %>_cleanup.rb"
        puts
      end
    rescue => e
      puts "❌ Error: #{e.message}"
      puts e.backtrace.first(5).join("\n")
      raise ActiveRecord::Rollback
    end
  end
end

AcceptanceFixture.setup
