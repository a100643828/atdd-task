# Test Suite Seed Script (Tagged Data Strategy)
#
# Suite: <%= suite_id %>
# Description: <%= description %>
# Generated: <%= Time.now.iso8601 %>
# Generated by: tester
#
# Usage:
#   cd <%= project_path %> && rails runner tests/<%= project_id %>/suites/<%= suite_id %>/fixtures/seed.rb [test_run_id]
#
# Tagged Data Strategy:
#   - 資料加上 test_run_id 標記
#   - cleanup 只清理標記的資料
#   - 避免與其他測試或真實資料衝突

require 'securerandom'

module TestSuite
  module <%= suite_id.gsub('-', '_').camelize %>
    class Seeder
      # 資料前綴（便於識別）
      PREFIX = "TEST-"

      attr_reader :test_run_id, :created_records

      def initialize(test_run_id = nil)
        @test_run_id = test_run_id || generate_run_id
        @created_records = []
      end

      def seed!
        puts "═" * 60
        puts "🌱 Test Suite Seed"
        puts "═" * 60
        puts "Suite: <%= suite_id %>"
        puts "Test Run ID: #{@test_run_id}"
        puts "═" * 60
        puts

        ActiveRecord::Base.transaction do
          # ─────────────────────────────────────────────────────────
          # 載入共用 fixtures（如果有）
          # ─────────────────────────────────────────────────────────
          <% if shared_fixtures&.any? %>
          load_shared_fixtures
          <% end %>

          # ─────────────────────────────────────────────────────────
          # 建立測試資料
          # ─────────────────────────────────────────────────────────
          <% creates.each do |create| %>

          # <%= create[:description] || create[:entity] %>
          <%= create[:variable] %> = create_<%= create[:entity].underscore %>(
            <% create[:attributes].each do |key, value| %>
            <%= key %>: <%= value.inspect %>,
            <% end %>
          )
          record_created('<%= create[:entity] %>', <%= create[:variable] %>)
          <% end %>

          # ─────────────────────────────────────────────────────────
          # 輸出結果
          # ─────────────────────────────────────────────────────────
          puts
          puts "═" * 60
          puts "✅ Seed completed successfully!"
          puts "═" * 60
          puts "Test Run ID: #{@test_run_id}"
          puts "Records created: #{@created_records.count}"
          @created_records.each do |record|
            puts "  - #{record[:entity]}: #{record[:identifier]}"
          end
          puts "═" * 60
          puts
          puts "⚠️  After testing, run cleanup script:"
          puts "    rails runner tests/<%= project_id %>/suites/<%= suite_id %>/fixtures/cleanup.rb #{@test_run_id}"
          puts

          # 回傳結果供自動化使用
          {
            test_run_id: @test_run_id,
            records_created: @created_records.count,
            records: @created_records
          }
        end
      rescue => e
        puts "❌ Error: #{e.message}"
        puts e.backtrace.first(5).join("\n")
        raise ActiveRecord::Rollback
      end

      private

      def generate_run_id
        "run_#{Time.now.strftime('%Y%m%d%H%M%S')}_#{SecureRandom.hex(4)}"
      end

      def record_created(entity, record)
        identifier = record.respond_to?(:id) ? record.id : record.to_s
        @created_records << { entity: entity, identifier: identifier, id: record.id }
        puts "✅ Created #{entity}: #{identifier}"
      end

      def tag_metadata(base_metadata = {})
        base_metadata.merge(
          test_run_id: @test_run_id,
          test_suite: '<%= suite_id %>',
          created_at: Time.now.iso8601
        )
      end

      <% if shared_fixtures&.any? %>
      def load_shared_fixtures
        puts "📦 Loading shared fixtures..."
        # 載入共用 fixtures 的邏輯
        <% shared_fixtures.each do |fixture| %>
        # load_fixture('<%= fixture %>')
        <% end %>
      end
      <% end %>

      # ─────────────────────────────────────────────────────────────
      # Entity 建立方法（加上 test_run_id 標記）
      # ─────────────────────────────────────────────────────────────
      <% entities.each do |entity| %>

      def create_<%= entity[:name].underscore %>(attrs = {})
        # 加上識別前綴和 metadata
        attrs[:name] = "#{PREFIX}#{@test_run_id[0..7]}-#{attrs[:name]}" if attrs[:name]
        attrs[:email] = "#{PREFIX}#{@test_run_id[0..7]}-#{attrs[:email]}" if attrs[:email]

        # 如果 model 有 metadata 欄位，加上標記
        if <%= entity[:name] %>.column_names.include?('metadata')
          attrs[:metadata] = tag_metadata(attrs[:metadata] || {})
        end

        <%= entity[:name] %>.create!(attrs)
      end
      <% end %>
    end
  end
end

# 執行
if __FILE__ == $0
  test_run_id = ARGV[0]
  seeder = TestSuite::<%= suite_id.gsub('-', '_').camelize %>::Seeder.new(test_run_id)
  seeder.seed!
end
